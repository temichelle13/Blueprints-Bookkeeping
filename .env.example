# ============================================
# ENVIRONMENT CONFIGURATION FOR BLUEPRINTS & BOOKKEEPING
# ============================================
#
# PURPOSE:
# This .env.example file serves as a template for environment variables.
# It documents all configuration options needed to run the application
# and provides guidance on how to obtain the required credentials.
#
# USAGE:
# 1. Copy this file to create your local .env file:
#    cp .env.example .env
#
# 2. Fill in the actual values for each variable in your .env file
#    (NEVER commit your .env file to version control - it contains secrets!)
#
# 3. Required variables MUST be set for the application to start
#    Optional variables enable specific features when configured
#
# 4. The application validates all environment variables at startup
#    and will show detailed error messages if any required values are missing
#
# SECURITY NOTES:
# - The .env file contains sensitive credentials and should NEVER be committed
# - Use strong, randomly generated values for tokens and secrets
# - Rotate credentials regularly in production environments
# - Review access logs and monitor for unauthorized access attempts
#
# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# Database
# ============================================
# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origin URLs for production
# Example: https://blueprintsandbookkeeping.com,https://www.blueprintsandbookkeeping.com
# Leave empty for development (allows all origins)
CORS_ORIGIN=

# Base URL for the website (used in emails and redirects)
# Default: https://blueprintsandbookkeeping.com
# For local development, you might use: http://localhost:3000
SITE_URL=https://blueprintsandbookkeeping.com

# ============================================
# Authentication & Security
# ============================================
# Admin access token - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# ============================================
# Email - Resend
# ============================================
# Resend API key for email sending
RESEND_API_KEY=

# Webhook secret for Resend webhook verification (optional)
RESEND_WEBHOOK_SECRET=

# Owner email address for notifications
OWNER_EMAIL=

# Owner phone number for SMS notifications (optional)
# Format: +15551234567 (E.164 format with country code)
# Only used if Twilio is configured below
OWNER_PHONE_NUMBER=

# ============================================
# Adobe Sign (Optional)
# ============================================
# Adobe Sign OAuth credentials
ADOBE_SIGN_CLIENT_ID=
ADOBE_SIGN_CLIENT_SECRET=
ADOBE_SIGN_REFRESH_TOKEN=
ADOBE_SIGN_REDIRECT_URI=

# Adobe Sign API base URL (optional)
# Default: https://api.na1.adobesign.com/api/rest/v6
# Change if using a different region (e.g., eu1, au1, jp1) for REST API calls only.
# NOTE: The OAuth refresh endpoint is currently hard-coded to the na1 host in
# artifacts/api-server/src/lib/adobe-sign.ts, so changing this value will NOT
# change where token refresh requests are sent. Non-na1 deployments may require
# code changes to fully support region-specific OAuth hosts.
ADOBE_SIGN_BASE_URL=https://api.na1.adobesign.com/api/rest/v6

# ============================================
# Stripe Payment Processing
# ============================================
# Stripe secret key
STRIPE_SECRET_KEY=

# Stripe webhook secret for webhook verification
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs for subscription plans
# These correspond to the Essentials and Growth bookkeeping plans
# You can find these IDs in your Stripe dashboard under Products
STRIPE_ESSENTIALS_MONTHLY_PRICE_ID=
STRIPE_ESSENTIALS_ANNUAL_PRICE_ID=
STRIPE_GROWTH_MONTHLY_PRICE_ID=
STRIPE_GROWTH_ANNUAL_PRICE_ID=

# ============================================
# Cal.com Booking Integration (Optional)
# ============================================
# Webhook secret for Cal.com webhook verification
# Also supports legacy Calendly webhooks
CAL_WEBHOOK_SECRET=

# Secret required for the booking webhook endpoint (/contracts/webhooks/booking)
# You may reuse the same value as CAL_WEBHOOK_SECRET if desired
BOOKING_WEBHOOK_SECRET=

# ============================================
# Twilio SMS Notifications (Optional)
# ============================================
# Twilio credentials for SMS notifications to the owner
# Sign up at https://www.twilio.com to get these credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio phone number to send SMS from
# Format: +15551234567 (must be a Twilio number you own)
TWILIO_FROM_NUMBER=

# ============================================
# OpenAI
# ============================================
# OpenAI API key for AI features
OPENAI_API_KEY=

# OpenAI model to use for chat (default: gpt-4o-mini)
OPENAI_CHAT_MODEL=gpt-4o-mini

# ============================================
# Apollo.io Integration (Optional)
# ============================================
APOLLO_API_KEY=
