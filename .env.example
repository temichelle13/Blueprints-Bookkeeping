# Environment Configuration
# Copy this file to .env and fill in the values

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# Database
# ============================================
# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origin URLs for production
# Example: https://blueprintsandbookkeeping.com,https://www.blueprintsandbookkeeping.com
# Leave empty for development (allows all origins)
CORS_ORIGIN=

# ============================================
# Authentication & Security
# ============================================
# Admin access token - MUST be at least 32 characters
# Generate with: openssl rand -hex 32
ADMIN_TOKEN=

# ============================================
# Email - Resend
# ============================================
# Resend API key for email sending
RESEND_API_KEY=

# Webhook secret for Resend webhook verification (optional)
RESEND_WEBHOOK_SECRET=

# Owner email address for notifications
OWNER_EMAIL=

# ============================================
# Adobe Sign (Optional)
# ============================================
# Adobe Sign OAuth credentials
ADOBE_SIGN_CLIENT_ID=
ADOBE_SIGN_CLIENT_SECRET=
ADOBE_SIGN_REFRESH_TOKEN=
ADOBE_SIGN_REDIRECT_URI=

# ============================================
# Stripe Payment Processing
# ============================================
# Stripe secret key
STRIPE_SECRET_KEY=

# Stripe webhook secret for webhook verification
STRIPE_WEBHOOK_SECRET=

# Stripe price IDs for different plans
STRIPE_PRICE_ID_MONTHLY_LITE=
STRIPE_PRICE_ID_ANNUAL_LITE=
STRIPE_PRICE_ID_MONTHLY_STANDARD=
STRIPE_PRICE_ID_ANNUAL_STANDARD=
STRIPE_PRICE_ID_MONTHLY_PREMIUM=
STRIPE_PRICE_ID_ANNUAL_PREMIUM=

# ============================================
# Cal.com Booking Integration (Optional)
# ============================================
CAL_WEBHOOK_SECRET=

# ============================================
# OpenAI
# ============================================
# OpenAI API key for AI features (Aria chat assistant)
# Either OPENAI_API_KEY or AI_INTEGRATIONS_OPENAI_API_KEY must be set for the AI chat to work
OPENAI_API_KEY=

# Alternative env var name for the OpenAI API key (takes precedence over OPENAI_API_KEY)
# AI_INTEGRATIONS_OPENAI_API_KEY=

# Optional: Custom OpenAI-compatible base URL (leave unset to use the default OpenAI API endpoint)
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# OpenAI model to use for chat (default: gpt-4.1-mini)
OPENAI_CHAT_MODEL=gpt-4.1-mini

# ============================================
# Apollo.io Integration (Optional)
# ============================================
APOLLO_API_KEY=
