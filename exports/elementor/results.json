            "_column_size": 100
          },
          "elements": [
            {
              "id": "elem00007s",
              "elType": "widget",
              "widgetType": "icon-box",
              "settings": {
                "title_text": "From Chaos to SBA Approval in 90 Days",
                "description_text": "<p style=\"margin-bottom:8px;\"><span style=\"background:#161B2E;color:#6366F1;padding:4px 12px;border-radius:999px;font-size:11px;font-weight:600;letter-spacing:2px;\">AGRICULTURE & TIMBER</span> <span style=\"color:#8B91A0;font-size:13px;margin-left:8px;\">AgriTech Founder — Pacific Northwest</span></p>\n\n<div style=\"display:grid;grid-template-columns:1fr 1fr 1fr;gap:24px;margin-top:24px;\">\n<div>\n<p style=\"color:#8B91A0;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;\">🎯 THE CHALLENGE</p>\n<p style=\"color:#D8DCE4;font-size:15px;line-height:1.7;\">A second-generation timber and agriculture operation had grown from a single LLC into four interrelated entities over five years. The books were a patchwork of spreadsheets, shoe-box receipts, and a neglected QuickBooks file. Two lender applications for a $400K equipment line had been declined due to unreliable financials.</p>\n</div>\n<div>\n<p style=\"color:#8B91A0;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;\">💡 OUR APPROACH</p>\n<p style=\"color:#D8DCE4;font-size:15px;line-height:1.7;\">We performed a full historical cleanup across all four entities, reconciled 36 months of bank and credit card statements, and built a consolidated chart of accounts in QuickBooks Online. Then we developed a lender-ready 5-year business plan with realistic revenue projections backed by historical data.</p>\n</div>\n<div>\n<p style=\"color:#8B91A0;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px;\">📈 THE OUTCOMES</p>\n<ul style=\"list-style:none;padding:0;\"><li style=\"margin-bottom:8px;color:#D8DCE4;font-size:15px;\">✓ 36 months of financials reconciled across 4 entities</li><li style=\"margin-bottom:8px;color:#D8DCE4;font-size:15px;\">✓ $400K equipment line of credit approved on first submission</li><li style=\"margin-bottom:8px;color:#D8DCE4;font-size:15px;\">✓ Monthly close time reduced from 3 weeks to 3 days</li><li style=\"margin-bottom:8px;color:#D8DCE4;font-size:15px;\">✓ Ongoing advisory retainer for growth planning</li></ul>\n</div>\n</div>\n\n<div style=\"margin-top:24px;padding-top:20px;border-top:1px solid #252B3D;\">\n<a href=\"/contact\" style=\"color:#6366F1;font-weight:600;font-size:14px;\">Get results like these — Book a discovery call →</a>\n</div>",
                "selected_icon": {
                  "value": "fas fa-chart-line",
                  "library": "fa-solid"
                },
                "icon_color": "#6366F1",
                "title_color": "#FFFFFF",
                "title_typography_typography": "custom",
                "title_typography_font_size": {
                  "unit": "px",
                  "size": 24
                },
                "background_background": "classic",
                "background_color": "#161B2E",
                "border_border": "solid",
                "border_width": {
                  "unit": "px",
                  "top": 1,
                  "right": 1,
